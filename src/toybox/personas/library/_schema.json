{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toybox.local/schemas/persona.json",
  "title": "Persona",
  "description": "Schema for a single persona library entry shipped under src/toybox/personas/library/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "display_name",
    "archetype",
    "system_prompt",
    "avatar_image_path",
    "behavior_tags",
    "age_range_min",
    "age_range_max",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "minLength": 1,
      "maxLength": 64
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "archetype": {
      "type": "string",
      "enum": ["princess", "wizard", "detective", "periodic_table", "custom"]
    },
    "system_prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "avatar_image_path": {
      "type": "string",
      "pattern": "^library/avatars/[a-z0-9_-]+\\.png$"
    },
    "behavior_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "minItems": 1,
      "maxItems": 32
    },
    "age_range_min": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99
    },
    "age_range_max": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32,
      "default": "en"
    },
    "source": {
      "type": "string",
      "enum": ["library"]
    },
    "default_voice_tone": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "role_weights": {
      "type": "object",
      "description": "Phase K K1 — role-name -> 0.0..2.0 weight. Empty = uniform.",
      "additionalProperties": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 2.0
      },
      "propertyNames": {
        "enum": [
          "friend",
          "quest_giver",
          "guide_mentor",
          "needs_saving",
          "boss_mini_boss",
          "big_bad_boss",
          "frenemy",
          "sidekick",
          "trickster",
          "helper_townsperson"
        ]
      }
    },
    "voice_profile": {
      "type": ["object", "null"],
      "description": "Phase K K1/K8 — TTS voice profile; NULL = system default.",
      "additionalProperties": false,
      "required": ["rate", "pitch"],
      "properties": {
        "rate": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.0
        },
        "pitch": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 2.0
        },
        "voice_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "neural_voice": {
          "type": "string",
          "description": "Phase Z Z3 — Kokoro voice id (e.g. am_michael); absent = default af_heart.",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "spontaneity_rates": {
      "type": "object",
      "description": "Phase K K1 — per-content max-rate input for K15's spontaneity roll.",
      "additionalProperties": false,
      "required": ["jokes", "songs"],
      "properties": {
        "jokes": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "songs": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    }
  }
}
