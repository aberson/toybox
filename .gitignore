# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.uv/
# Coqui TTS one-shot render venv — populated by scripts/generate_song_corpus.py.
# Multi-GB model weights; kept out of git per the script's docstring rationale.
.coqui-venv/
.coqui-venv-*/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend
node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
*.log
npm-debug.log*

# Toybox runtime data (gitignore everything in data/ except the
# directory placeholders so the model-cache layout is shipped in git
# but the binaries themselves stay out of the repo).
data/*
!data/.gitkeep
!data/models/
data/models/*
# F.5-3b Tier C composite templates ARE shipped in the repo (CC0 art /
# operator-drawn) — un-ignore them so composite.py can read from disk
# and operators can iterate on the art without touching .gitignore.
!data/sprites/
!data/sprites/templates/
!data/sprites/templates/**
!data/models/.gitkeep
# LoRA registry — track REGISTRY.md + .gitkeep, ignore trained adapter
# subdirectories (data/models/lora/<timestamp>/). The lora/ dir itself is
# un-ignored so git can recurse into it; the trailing slash on the second
# rule matches only directories.
!data/models/lora/
data/models/lora/*/
# Phase K K10: ship the bundled joke corpus in git. The directory + JSON
# file are operator-authored content (no binaries), so they belong in the
# repo so a fresh clone + ``uv run python -m toybox.main`` works without
# a separate "download corpus" step.
!data/jokes/
!data/jokes/jokes.json
# Phase K K11: ship the song manifest + credits in git, but NOT the
# rendered audio. The operator runs scripts/generate_song_corpus.py
# once locally to populate data/songs/audio/*.mp3. K11 deliberately
# keeps the heavyweight Coqui dep out of the runtime venv.
!data/songs/
!data/songs/manifest.json
!data/songs/_credits.md
data/songs/audio/
# Phase M M1: ship the bundled element corpus in git (same pattern as
# songs/jokes). The 118-entry JSON + credits are operator-authored
# content, no binaries — they belong in the repo so a fresh clone loads
# Phase M templates correctly. Sprite images are handled separately
# under data/images/elements/ by Phase M M2 (gitignored except a
# 14-element canonical subset).
!data/elements/
!data/elements/elements.json
!data/elements/_credits.md

# Secrets / OAuth
secrets.json
.env
.env.local

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Playwright
test-results/
playwright-report/
playwright/.cache/

# build-step UI review evidence (ephemeral; per-run output)
.ui-review-evidence/

# Claude Code (user-local settings + ephemeral worktrees; project settings.json is committed)
.claude/settings.local.json
.claude/worktrees/

# Runtime logs (backend.log/.err, frontend.log/.err — captured by the
# M2.5 setup script's Start-Process redirects). The *.log pattern above
# already covers .log files; this catches the .err siblings too.
logs/

# Operator scratch
zzscratch.txt
