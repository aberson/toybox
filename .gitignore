# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.uv/
# Coqui TTS one-shot render venv — populated by scripts/generate_song_corpus.py.
# Multi-GB model weights; kept out of git per the script's docstring rationale.
.coqui-venv/
.coqui-venv-*/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend
node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
*.log
npm-debug.log*

# Toybox runtime data (gitignore everything in data/ except the
# directory placeholders so the model-cache layout is shipped in git
# but the binaries themselves stay out of the repo).
data/*
!data/.gitkeep
!data/models/
data/models/*
# F.5-3b Tier C composite templates ARE shipped in the repo (CC0 art /
# operator-drawn) — un-ignore them so composite.py can read from disk
# and operators can iterate on the art without touching .gitignore.
!data/sprites/
!data/sprites/templates/
!data/sprites/templates/**
!data/models/.gitkeep
# LoRA registry — track REGISTRY.md + .gitkeep, ignore trained adapter
# subdirectories (data/models/lora/<timestamp>/). The lora/ dir itself is
# un-ignored so git can recurse into it; the trailing slash on the second
# rule matches only directories.
!data/models/lora/
data/models/lora/*/
# Phase K K10: ship the bundled joke corpus in git. The directory + JSON
# file are operator-authored content (no binaries), so they belong in the
# repo so a fresh clone + ``uv run python -m toybox.main`` works without
# a separate "download corpus" step.
!data/jokes/
!data/jokes/jokes.json
# Phase K K11: ship the song manifest + credits in git, but NOT the
# rendered audio. The operator runs scripts/generate_song_corpus.py
# once locally to populate data/songs/audio/*.mp3. K11 deliberately
# keeps the heavyweight Coqui dep out of the runtime venv.
!data/songs/
!data/songs/manifest.json
!data/songs/_credits.md
data/songs/audio/
# Phase M M1: ship the bundled element corpus in git (same pattern as
# songs/jokes). The 118-entry JSON + credits are operator-authored
# content, no binaries — they belong in the repo so a fresh clone loads
# Phase M templates correctly. Sprite images are handled separately
# under data/images/elements/ by Phase M M2 (gitignored except a
# 14-element canonical subset).
!data/elements/
!data/elements/elements.json
!data/elements/_credits.md
# Phase M M2: ship 14 canonical element sprites in git (one per
# Family enum value + popular individuals). Other 104 sprites are
# rendered locally by scripts/generate_element_sprites.py and stay
# out of git to keep repo size sane.
#
# .gitignore-pattern surgery: data/* at line 31 is the root wildcard.
# To selectively include data/images/elements/<14 files>.png we have
# to (a) un-ignore the directory chain so git traverses into it, then
# (b) re-ignore the *sibling* subdirs under data/images/ that ARE
# runtime-generated and should stay out of git, then (c) re-ignore
# everything under data/images/elements/, then (d) un-ignore the 14
# specific PNGs. Without step (b), the un-ignore of data/images/ in
# step (a) cascades to data/images/personas/*, data/images/rewards/*,
# data/images/toy_actions/*, data/images/.staging/*, data/images/
# rooms/*, data/images/toys/* — none of which belong in git.
!data/images/
# Step (b): explicitly re-ignore every runtime-image subdir.
data/images/.staging/
data/images/personas/
data/images/rewards/
data/images/rooms/
data/images/toys/
data/images/toy_actions/
# Step (c) + (d): allow data/images/elements/ but only for the 14
# canonical PNGs.
!data/images/elements/
data/images/elements/*
!data/images/elements/h-1.png
!data/images/elements/he-2.png
!data/images/elements/li-3.png
!data/images/elements/c-6.png
!data/images/elements/o-8.png
!data/images/elements/f-9.png
!data/images/elements/ne-10.png
!data/images/elements/al-13.png
!data/images/elements/si-14.png
!data/images/elements/ca-20.png
!data/images/elements/fe-26.png
!data/images/elements/au-79.png
!data/images/elements/la-57.png
!data/images/elements/u-92.png

# Secrets / OAuth
secrets.json
.env
.env.local

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Playwright
test-results/
playwright-report/
playwright/.cache/

# build-step UI review evidence (ephemeral; per-run output)
.ui-review-evidence/

# Claude Code (user-local settings + ephemeral worktrees; project settings.json is committed)
.claude/settings.local.json
.claude/worktrees/

# Runtime logs (backend.log/.err, frontend.log/.err — captured by the
# M2.5 setup script's Start-Process redirects). The *.log pattern above
# already covers .log files; this catches the .err siblings too.
logs/

# Operator scratch
zzscratch.txt
.plan-expedite-state
