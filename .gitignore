# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.uv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend
node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
*.log
npm-debug.log*

# Toybox runtime data (gitignore everything in data/ except the
# directory placeholders so the model-cache layout is shipped in git
# but the binaries themselves stay out of the repo).
data/*
!data/.gitkeep
!data/models/
data/models/*
# F.5-3b Tier C composite templates ARE shipped in the repo (CC0 art /
# operator-drawn) — un-ignore them so composite.py can read from disk
# and operators can iterate on the art without touching .gitignore.
!data/sprites/
!data/sprites/templates/
!data/sprites/templates/**
!data/models/.gitkeep

# Secrets / OAuth
secrets.json
.env
.env.local

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Playwright
test-results/
playwright-report/
playwright/.cache/

# build-step UI review evidence (ephemeral; per-run output)
.ui-review-evidence/

# Claude Code (user-local settings + ephemeral worktrees; project settings.json is committed)
.claude/settings.local.json
.claude/worktrees/

# Runtime logs (backend.log/.err, frontend.log/.err — captured by the
# M2.5 setup script's Start-Process redirects). The *.log pattern above
# already covers .log files; this catches the .err siblings too.
logs/

# Operator scratch
zzscratch.txt
